{
  "expo": {
    "name": "VoxLingo",
    "slug": "voxlingo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoxLingo a besoin du micro pour evaluer votre prononciation."
      }
    },
    "android": {
      "package": "com.voxlingo.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "voxlingo",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f4072b2-2655-4e71-a665-656611d85c12"
      }
    }
  }
}
